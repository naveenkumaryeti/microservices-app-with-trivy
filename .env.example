# ── Database ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

DB_HOST=database
DB_PORT=5432
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=changeme          # CHANGE THIS in production

# ── Backend ───────────────────────────────────────────────────────────────────
PORT=3000
APP_VERSION=local

# ── Frontend ──────────────────────────────────────────────────────────────────
# If the frontend needs to know the backend URL at build time:
# API_URL=http://localhost:3000
